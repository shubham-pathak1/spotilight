{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Spotilight",
  "version": "1.0.0",
  "identifier": "com.spotilight.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "url": "https://open.spotify.com",
        "title": "Spotilight",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "visible": false,
        "center": true,
        "decorations": true,
        "theme": "Dark",
        "additionalBrowserArgs": "--js-flags=--max-old-space-size=256"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
